{
  "manifest_version": 3,
  "name": "TabPack",
  "version": "1.0.0",
  "description": "Save Tab Groups as Local Files. Export browser tab groups as HTML, MHTML, or CSV files.",
  "permissions": [
    "tabs",
    "tabGroups",
    "pageCapture",
    "downloads",
    "scripting"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "action": {
    "default_title": "TabPack",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  }
}
