{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "types": [
      "chrome",
      "node"
    ],
    "strict": false,
    "skipLibCheck": true
  },
  "include": [
    "extension/**/*.js",
    "scripts/**/*.mjs",
    "tests/**/*.js",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "test-results"
  ]
}
